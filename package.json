{
  "type": "module",
  "main": "electron/main.js",
  "sideEffects": [
    "sources/state/catalog.ts",
    "sources/vendor-globals.ts"
  ],
  "name": "universal-lpc-spritesheet-character-generator",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "prebuild": "rimraf \"dist/!(spritesheets)\"",
    "build": "vite build",
    "preview": "vite preview",
    "serve": "vite",
    "serve:open": "vite --open",
    "lint": "eslint . --cache",
    "lint:fix": "eslint . --cache --fix",
    "type-check": "tsgo --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "validate-site-sources": "concurrently -c auto -n \"credits,zpos\" \"node scripts/generate_credits.js\" \"node scripts/zPositioning/parse_zpos.js\"",
    "z-positions": "node scripts/zPositioning/parse_zpos.js",
    "z-positions:update": "node scripts/zPositioning/update_zpos.js",
    "test": "npm run test:node && node ./node_modules/testem/testem.js ci",
    "test:node": "node ./tests/node/run-node-tests.js",
    "test:server": "node ./node_modules/testem/testem.js",
    "test:visual": "playwright test",
    "test:visual:headed": "playwright test --headed",
    "fixture:issue382": "node scripts/fixture-builder.js tests/fixtures/issue-382/issue-382-selections.json",
    "profile:zip": "node scripts/zip/zip-export-profile.js",
    "profile:zip:quick": "node scripts/zip/zip-export-profile.js --quick",
    "profile:zip:baseline": "node scripts/zip/zip-export-profile.js --out tmp/baseline-zip-export-profile.json",
    "profile:zip:baseline:quick": "node scripts/zip/zip-export-profile.js --quick --out tmp/baseline-zip-export-profile-quick.json",
    "diff:zip-profile": "node scripts/zip/diff-zip-profile.js",
    "compute-style-dump": "node scripts/computed-style/dump-computed-styles.js",
    "compute-style-dump:mobile": "node scripts/computed-style/dump-computed-styles.js --preset mobile",
    "compute-style-diff-all": "node scripts/computed-style/computed-style-diff-all.js",
    "compute-style-diff-all:preview-ports": "node scripts/computed-style/computed-style-diff-all.js --url-a http://localhost:4176 --url-b http://localhost:4177",
    "electron:dev": "npm run build && electron .",
    "electron:gui": "electron .",
    "electron:headless": "electron . --headless",
    "electron:random": "electron . --headless --random",
    "electron:list": "electron . --headless --list-items",
    "electron:build": "npm run build && electron-builder --win portable",
    "electron:build:dir": "npm run build && electron-builder --win --dir"
  },
  "dependencies": {
    "bulma": "1.0.4",
    "classnames": "^2.5.1",
    "jszip": "^3.10.1",
    "mithril": "^2.3.8",
    "neverthrow": "^8.2.0",
    "tinygesture": "^3.0.0"
  },
  "devDependencies": {
    "@argos-ci/playwright": "^7.0.5",
    "@babel/eslint-parser": "^7.28.6",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.60.0",
    "@tsconfig/strictest": "^2.0.8",
    "@types/mithril": "^2.2.8",
    "@types/node": "^25.6.0",
    "@typescript/native-preview": "^7.0.0-beta.1",
    "chai": "^6.2.2",
    "concurrently": "^10.0.3",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "execa": "^9.6.1",
    "globals": "^16.5.0",
    "mocha": "^11.7.5",
    "open": "^10.2.0",
    "prettier": "^3.8.1",
    "purgecss": "^6.0.0",
    "rimraf": "^6.1.3",
    "sass-embedded": "^1.99.0",
    "serve": "^14.2.6",
    "sinon": "^21.1.2",
    "testem": "^3.20.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^8.0.16",
    "vite-multiple-assets": "^2.2.6",
    "vite-plugin-cp": "^6.0.3",
    "vite-plugin-run": "^0.8.0",
    "vite-plugin-testem": "^1.0.1"
  },
  "overrides": {
    "@babel/core": "^7.28.6",
    "minimatch@^10.2.5": {
      "brace-expansion": "^5.0.6"
    },
    "mocha": {
      "diff": "^8.0.3",
      "minimatch": "^9.0.7",
      "serialize-javascript": "^7.0.5"
    }
  },
  "build": {
    "appId": "com.kojeomstudio.lpc-sprite-generator",
    "productName": "LPC Sprite Generator",
    "directories": {
      "output": "../../bins/lpc-sprite-generator",
      "buildResources": "build-resources"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json",
      "!dist/spritesheets/**"
    ],
    "extraResources": [
      {
        "from": "dist/spritesheets",
        "to": "dist/spritesheets",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "artifactName": "LPC-SpriteGenerator-${version}-portable.exe"
    }
  }
}

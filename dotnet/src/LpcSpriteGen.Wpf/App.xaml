<Application x:Class="LpcSpriteGen.Wpf.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <!--
        VS 2026 Light theme palette (mirrors Visual Studio 2026 default "Light" color theme).
        Reference: https://learn.microsoft.com/visualstudio/designers/shared-colors
        - Window background:   #FFFFFF (white editor pane)
        - Panel/secondary:     #F5F5F5 (tool windows)
        - Titlebar/tabs:       #F0F0F0 (titlebar strip)
        - Border/divider:      #E5E5E5 (subtle gray border)
        - Accent:              #007ACC (VS blue)
        - Accent hover:        #1C97EA
        - Accent pressed:      #0067B5
        - Text primary:        #1E1E1E (editor foreground, near-black)
        - Text secondary:      #6A6A6A (muted)
        - List/row hover:      #C9DEF5
        - List/row selected:   #007ACC (with white text)
        - Success:             #107C10
        - Warning:             #B89500
        - Error:               #C50F1F
    -->
    <Application.Resources>
        <Color x:Key="VsBackground">#FFFFFF</Color>
        <Color x:Key="VsPanel">#F5F5F5</Color>
        <Color x:Key="VsTitlebar">#F0F0F0</Color>
        <Color x:Key="VsBorder">#E5E5E5</Color>
        <Color x:Key="VsAccent">#007ACC</Color>
        <Color x:Key="VsAccentHover">#1C97EA</Color>
        <Color x:Key="VsAccentPressed">#0067B5</Color>
        <Color x:Key="VsTextPrimary">#1E1E1E</Color>
        <Color x:Key="VsTextSecondary">#6A6A6A</Color>
        <Color x:Key="VsListHover">#C9DEF5</Color>
        <Color x:Key="VsSuccess">#107C10</Color>
        <Color x:Key="VsWarning">#B89500</Color>
        <Color x:Key="VsError">#C50F1F</Color>

        <SolidColorBrush x:Key="VsBackgroundBrush" Color="{StaticResource VsBackground}"/>
        <SolidColorBrush x:Key="VsPanelBrush" Color="{StaticResource VsPanel}"/>
        <SolidColorBrush x:Key="VsTitlebarBrush" Color="{StaticResource VsTitlebar}"/>
        <SolidColorBrush x:Key="VsBorderBrush" Color="{StaticResource VsBorder}"/>
        <SolidColorBrush x:Key="VsAccentBrush" Color="{StaticResource VsAccent}"/>
        <SolidColorBrush x:Key="VsAccentHoverBrush" Color="{StaticResource VsAccentHover}"/>
        <SolidColorBrush x:Key="VsAccentPressedBrush" Color="{StaticResource VsAccentPressed}"/>
        <SolidColorBrush x:Key="VsTextPrimaryBrush" Color="{StaticResource VsTextPrimary}"/>
        <SolidColorBrush x:Key="VsTextSecondaryBrush" Color="{StaticResource VsTextSecondary}"/>
        <SolidColorBrush x:Key="VsListHoverBrush" Color="{StaticResource VsListHover}"/>
        <SolidColorBrush x:Key="VsSuccessBrush" Color="{StaticResource VsSuccess}"/>
        <SolidColorBrush x:Key="VsWarningBrush" Color="{StaticResource VsWarning}"/>
        <SolidColorBrush x:Key="VsErrorBrush" Color="{StaticResource VsError}"/>

        <!-- Button: flat with subtle border, blue accent on hover/press -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource VsTextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource VsBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource VsListHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource VsAccentBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary action button: solid blue accent (white text) -->
        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource VsAccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource VsAccentBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Style.Triggers>
                <EventTrigger RoutedEvent="Button.MouseEnter">
                    <BeginStoryboard>
                        <Storyboard>
                            <ColorAnimation Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                            To="{StaticResource VsAccentHover}" Duration="0:0:0.1"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <EventTrigger RoutedEvent="Button.MouseLeave">
                    <BeginStoryboard>
                        <Storyboard>
                            <ColorAnimation Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                            To="{StaticResource VsAccent}" Duration="0:0:0.1"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource VsTextPrimaryBrush}"/>
        </Style>

        <Style TargetType="Label">
            <Setter Property="Foreground" Value="{StaticResource VsTextPrimaryBrush}"/>
        </Style>

        <!-- TextBox: white bg, dark text (주된 문제 — 다크 테마에선 흰 글씨가 흰 배경에 묻혔음) -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="{StaticResource VsTextPrimaryBrush}"/>
            <Setter Property="CaretBrush" Value="{StaticResource VsTextPrimaryBrush}"/>
            <Setter Property="SelectionBrush" Value="{StaticResource VsAccentBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource VsBorderBrush}"/>
            <Setter Property="Padding" Value="5,3"/>
            <Setter Property="MinHeight" Value="26"/>
        </Style>

        <!-- ComboBox: white bg, dark text (드롭다운 글씨 안 보이던 주범) -->
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="{StaticResource VsTextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource VsBorderBrush}"/>
            <Setter Property="MinHeight" Value="26"/>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{StaticResource VsTextPrimaryBrush}"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Padding" Value="6,3"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource VsListHoverBrush}"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource VsAccentBrush}"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="{StaticResource VsTextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource VsBorderBrush}"/>
        </Style>
        <Style TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="{StaticResource VsTextPrimaryBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="6,3"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource VsListHoverBrush}"/>
                    <Setter Property="Foreground" Value="{StaticResource VsTextPrimaryBrush}"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource VsListHoverBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TreeView">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="{StaticResource VsTextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource VsBorderBrush}"/>
        </Style>
        <Style TargetType="TreeViewItem">
            <Setter Property="Foreground" Value="{StaticResource VsTextPrimaryBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="2"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource VsListHoverBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Slider">
            <Setter Property="Foreground" Value="{StaticResource VsAccentBrush}"/>
        </Style>

        <Style TargetType="GroupBox">
            <Setter Property="Foreground" Value="{StaticResource VsTextPrimaryBrush}"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource VsBorderBrush}"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="Margin" Value="0,4"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource VsTextPrimaryBrush}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="StatusBar">
            <Setter Property="Background" Value="{StaticResource VsAccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style TargetType="StatusBarItem">
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style TargetType="Menu">
            <Setter Property="Background" Value="{StaticResource VsTitlebarBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource VsTextPrimaryBrush}"/>
        </Style>
        <Style TargetType="MenuItem">
            <Setter Property="Foreground" Value="{StaticResource VsTextPrimaryBrush}"/>
            <Setter Property="Background" Value="{StaticResource VsTitlebarBrush}"/>
            <Setter Property="Padding" Value="8,3"/>
        </Style>

        <!-- TabControl: top-aligned VS-style tabs with accent underline on selected -->
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="{StaticResource VsBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource VsBorderBrush}"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="{StaticResource VsTextSecondaryBrush}"/>
            <Setter Property="Background" Value="{StaticResource VsTitlebarBrush}"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderThickness="0,0,1,0" BorderBrush="{StaticResource VsBorderBrush}">
                            <Grid>
                                <ContentPresenter ContentSource="Header"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  Margin="{TemplateBinding Padding}"/>
                                <Rectangle x:Name="accentBar" Height="2" VerticalAlignment="Bottom"
                                           Fill="{StaticResource VsAccentBrush}" Opacity="0"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource VsListHoverBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource VsTextPrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource VsBackgroundBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource VsTextPrimaryBrush}"/>
                                <Setter TargetName="accentBar" Property="Opacity" Value="1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource VsPanelBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource VsBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0,4"/>
        </Style>

        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource VsAccentBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
        </Style>

        <Style x:Key="StatusGood" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource VsSuccessBrush}"/>
        </Style>
    </Application.Resources>
</Application>

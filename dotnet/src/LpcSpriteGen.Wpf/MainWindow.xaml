<Window x:Class="LpcSpriteGen.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LPC Sprite Generator"
        Height="950" Width="1500"
        Background="{StaticResource VsBackgroundBrush}"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded">
    <Window.Resources>
        <!-- Grouped item template: name on top, small itemId + type below -->
        <DataTemplate x:Key="SelectionRowTemplate">
            <Border Background="{StaticResource VsPanelBrush}" CornerRadius="3" Padding="8,4" Margin="0,2">
                <DockPanel>
                    <Button DockPanel.Dock="Right" Content="✕" Width="22" Height="22"
                            Padding="0" Margin="6,0,0,0"
                            Tag="{Binding TypeName}"
                            Click="RemoveSelection_Click" ToolTip="Remove this item"/>
                    <StackPanel>
                        <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding DetailLine}" FontSize="11"
                                   Foreground="{StaticResource VsTextSecondaryBrush}"/>
                    </StackPanel>
                </DockPanel>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <DockPanel>
        <!-- Top: titlebar strip with brand + window controls placeholder -->
        <Border DockPanel.Dock="Top" Background="{StaticResource VsTitlebarBrush}" Padding="14,8">
            <DockPanel>
                <TextBlock Text="LPC SPRITE GENERATOR" FontWeight="Bold" FontSize="12"
                           Foreground="{StaticResource VsAccentBrush}" VerticalAlignment="Center"/>
                <TextBlock Text="C# / WPF edition" FontSize="11"
                           Foreground="{StaticResource VsTextSecondaryBrush}"
                           VerticalAlignment="Center" Margin="12,0,0,0"/>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                    <Button Content="🎲 Randomize" Click="Randomize_Click" Style="{StaticResource PrimaryButton}" Margin="2,0"/>
                    <Button Content="💾 Export PNG" Click="ExportPng_Click" Margin="2,0"/>
                    <Button Content="💾 Save Selections" Click="Save_Click" Margin="2,0"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Menu bar -->
        <Menu DockPanel.Dock="Top" Background="{StaticResource VsTitlebarBrush}">
            <MenuItem Header="_File">
                <MenuItem Header="_New (reset to default)" Click="New_Click" InputGestureText="Ctrl+N"/>
                <MenuItem Header="_Open selections..." Click="Open_Click" InputGestureText="Ctrl+O"/>
                <MenuItem Header="_Save selections..." Click="Save_Click" InputGestureText="Ctrl+S"/>
                <Separator/>
                <MenuItem Header="Export _PNG..." Click="ExportPng_Click" InputGestureText="Ctrl+E"/>
                <MenuItem Header="Export _ZIP (by animation)..." Click="ExportZipAnim_Click"/>
                <MenuItem Header="Export Z_IP (by frame)..." Click="ExportZipFrame_Click"/>
                <MenuItem Header="Export _credits (TXT)..." Click="ExportCredits_Click"/>
                <Separator/>
                <MenuItem Header="E_xit" Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="_Character">
                <MenuItem Header="_Randomize" Click="Randomize_Click" InputGestureText="Ctrl+R"/>
                <MenuItem Header="Randomize with _seed..." Click="RandomizeSeeded_Click"/>
                <Separator/>
                <MenuItem Header="Body type _male" Tag="male" Click="BodyTypeMenu_Click"/>
                <MenuItem Header="Body type _female" Tag="female" Click="BodyTypeMenu_Click"/>
                <MenuItem Header="Body type _teen" Tag="teen" Click="BodyTypeMenu_Click"/>
                <MenuItem Header="Body type _child" Tag="child" Click="BodyTypeMenu_Click"/>
                <MenuItem Header="Body type m_uscular" Tag="muscular" Click="BodyTypeMenu_Click"/>
                <MenuItem Header="Body type pre_gnant" Tag="pregnant" Click="BodyTypeMenu_Click"/>
            </MenuItem>
            <MenuItem Header="_Tools">
                <MenuItem Header="Open log folder" Click="OpenLogFolder_Click"/>
                <MenuItem Header="Open _headless CLI help" Click="ShowCliHelp_Click"/>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_About" Click="About_Click"/>
            </MenuItem>
        </Menu>

        <!-- Status bar -->
        <StatusBar DockPanel.Dock="Bottom" Padding="8,3">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="Ready"/>
            </StatusBarItem>
            <Separator Background="#66FFFFFF"/>
            <StatusBarItem>
                <TextBlock x:Name="SelectionCountText" Text="0 items"/>
            </StatusBarItem>
            <Separator Background="#66FFFFFF"/>
            <StatusBarItem>
                <TextBlock x:Name="RenderTimeText" Text=""/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right" DockPanel.Dock="Right">
                <TextBlock x:Name="LogPathText" Text="" Foreground="White"/>
            </StatusBarItem>
        </StatusBar>

        <!-- Main content: top horizontal tabs -->
        <TabControl x:Name="MainTabs" TabStripPlacement="Top" Margin="0" Padding="0">
            <!-- ── Tab: Generate ─────────────────────────────────────────────────────── -->
            <TabItem Header="🎲 Generate">
                <DockPanel Background="{StaticResource VsBackgroundBrush}" Margin="0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="300" MinWidth="220"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Left: generation controls -->
                        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="10">
                                <TextBlock Text="QUICK START" Style="{StaticResource SectionHeader}"/>
                                <Button Click="Randomize_Click" Style="{StaticResource PrimaryButton}"
                                        HorizontalAlignment="Stretch" Margin="0,2">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🎲  " FontSize="14"/>
                                        <TextBlock Text="Generate Random Character"/>
                                    </StackPanel>
                                </Button>
                                <Button Click="RandomizeSeeded_Click" HorizontalAlignment="Stretch" Margin="0,2">
                                    Generate with Seed...
                                </Button>

                                <TextBlock Text="BODY TYPE" Style="{StaticResource SectionHeader}" Margin="0,16,0,4"/>
                                <ComboBox x:Name="BodyTypeBox" SelectionChanged="BodyType_SelectionChanged"
                                          HorizontalAlignment="Stretch" Margin="0,2"/>

                                <TextBlock Text="RESET" Style="{StaticResource SectionHeader}" Margin="0,16,0,4"/>
                                <Button Click="New_Click" HorizontalAlignment="Stretch" Margin="0,2">
                                    Reset to Default Character
                                </Button>
                                <Button Click="ClearAll_Click" HorizontalAlignment="Stretch" Margin="0,2">
                                    Clear All Selections
                                </Button>

                                <TextBlock Text="TIPS" Style="{StaticResource SectionHeader}" Margin="0,16,0,4"/>
                                <TextBlock TextWrapping="Wrap" FontSize="11"
                                           Foreground="{StaticResource VsTextSecondaryBrush}">
                                    • Use the Browse tab to pick individual parts.<LineBreak/>
                                    • Ctrl+wheel to zoom the preview.<LineBreak/>
                                    • Body, head and expression are always required.<LineBreak/>
                                    • Credits are saved alongside exports (legally required).
                                </TextBlock>
                            </StackPanel>
                        </ScrollViewer>

                        <GridSplitter Grid.Column="1" Width="4" Background="{StaticResource VsBorderBrush}"
                                      HorizontalAlignment="Stretch"/>

                        <!-- Right: large preview -->
                        <DockPanel Grid.Column="2" Margin="6">
                            <Border DockPanel.Dock="Top" Background="{StaticResource VsPanelBrush}"
                                    CornerRadius="4" Padding="8,5" Margin="0,0,0,6">
                                <DockPanel>
                                    <TextBlock Text="Preview" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right"
                                                HorizontalAlignment="Right">
                                        <TextBlock Text="Animation:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <ComboBox x:Name="AnimationBox" Width="130"
                                                  SelectionChanged="Animation_SelectionChanged"/>
                                        <TextBlock Text="Zoom:" VerticalAlignment="Center" Margin="12,0,6,0"/>
                                        <Slider x:Name="ZoomSlider" Width="140" Minimum="0.25" Maximum="4"
                                                Value="1" TickFrequency="0.25" ValueChanged="Zoom_Changed"/>
                                        <TextBlock x:Name="ZoomLabel" Text="100%" VerticalAlignment="Center"
                                                   Width="40" Margin="6,0,0,0"/>
                                    </StackPanel>
                                </DockPanel>
                            </Border>
                            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                                          Background="#0A0A0A">
                                <Image x:Name="PreviewImage" Stretch="None"
                                       RenderOptions.BitmapScalingMode="NearestNeighbor"
                                       MouseWheel="Preview_MouseWheel"/>
                            </ScrollViewer>
                        </DockPanel>
                    </Grid>
                </DockPanel>
            </TabItem>

            <!-- ── Tab: Browse ───────────────────────────────────────────────────────── -->
            <TabItem Header="🔍 Browse Parts">
                <DockPanel Background="{StaticResource VsBackgroundBrush}">
                    <Border DockPanel.Dock="Top" Background="{StaticResource VsPanelBrush}"
                            Padding="10,6" Margin="0,0,0,4">
                        <DockPanel>
                            <TextBlock Text="🔍" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="14"/>
                            <TextBox x:Name="SearchBox" TextChanged="Search_TextChanged"
                                     ToolTip="Filter items by name (≥2 chars)"/>
                        </DockPanel>
                    </Border>
                    <TreeView x:Name="CatalogTree" SelectedItemChanged="CatalogItem_Selected" Margin="6"/>
                </DockPanel>
            </TabItem>

            <!-- ── Tab: Selections ────────────────────────────────────────────────────── -->
            <TabItem Header="📋 Current Selections">
                <DockPanel Background="{StaticResource VsBackgroundBrush}" Margin="10">
                    <Border DockPanel.Dock="Top" Style="{StaticResource CardBorder}">
                        <DockPanel>
                            <TextBlock Text="CURRENT LAYERS" Style="{StaticResource SectionHeader}"
                                       VerticalAlignment="Center"/>
                            <Button DockPanel.Dock="Right" Content="Clear all" Click="ClearAll_Click"
                                    HorizontalAlignment="Right"/>
                        </DockPanel>
                    </Border>
                    <ListBox x:Name="SelectionsList"
                             ItemTemplate="{StaticResource SelectionRowTemplate}"
                             Background="Transparent" BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"/>
                </DockPanel>
            </TabItem>

            <!-- ── Tab: Credits &amp; Attribution ─────────────────────────────────────── -->
            <TabItem Header="📜 Credits">
                <DockPanel Background="{StaticResource VsBackgroundBrush}" Margin="10">
                    <Border DockPanel.Dock="Top" Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <TextBlock Text="ATTRIBUTION" Style="{StaticResource SectionHeader}"/>
                            <TextBlock TextWrapping="Wrap"
                                       Foreground="{StaticResource VsTextSecondaryBrush}" FontSize="12">
                                LPC assets are CC-BY / CC-BY-SA / GPL / OGA-BY. Attribution is
                                mandatory for redistribution. A credits file is automatically emitted
                                alongside every PNG export.
                            </TextBlock>
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <Button Content="Export credits.txt" Click="ExportCredits_Click" Margin="0,0,6,0"/>
                                <Button Content="Copy to clipboard" Click="CopyCredits_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <TextBox x:Name="CreditsBox" IsReadOnly="True"
                             FontFamily="Cascadia Mono, Consolas, monospace"
                             VerticalScrollBarVisibility="Auto"
                             TextWrapping="Wrap"/>
                </DockPanel>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
